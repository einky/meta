# Cross-repo pinned versions. Source this file from any script that needs a
# shared version: `set -a; . versions.env; set +a` (or `source versions.env`
# from bash and use the exported names).
#
# Bump a version here and downstream repos pick it up on their next build.

# Ren'Py SDK ─────────────────────────────────────────────────────────────────
RENPY_SDK_VERSION=8.5.2
RENPY_SDK_URL=https://www.renpy.org/dl/${RENPY_SDK_VERSION}/renpy-${RENPY_SDK_VERSION}-sdk.tar.bz2
RENPY_SDK_SHA256=cf9ed145e5b32521a4b2caddb4cd3073c64259ac51e1f7aab94a8a8ff72b55c4

# OS image build ─────────────────────────────────────────────────────────────
PI_GEN_BRANCH=arm64

# Toolchain ──────────────────────────────────────────────────────────────────
PYTHON_VERSION=3.11
