# Cross-repo pinned versions. Source this file from any script that needs a
# shared version: `set -a; . versions.env; set +a` (or `source versions.env`
# from bash and use the exported names).
#
# This is the SINGLE source of truth for shared version pins. Bump here and
# downstream repos pick it up on their next build. `buildroot_os` mirrors the
# engine/toolchain pins in its Buildroot packages; a CI parity check keeps them
# in sync (do not edit the buildroot copies independently).

# Ren'Py engine ──────────────────────────────────────────────────────────────
# Dev workstations install this SDK tarball (scripts/install-renpy-sdk.sh).
# buildroot_os builds the SAME version from source (package/renpy/renpy.mk).
RENPY_VERSION=8.5.2
RENPY_SDK_VERSION=${RENPY_VERSION}
RENPY_SDK_URL=https://www.renpy.org/dl/${RENPY_SDK_VERSION}/renpy-${RENPY_SDK_VERSION}-sdk.tar.bz2
RENPY_SDK_SHA256=cf9ed145e5b32521a4b2caddb4cd3073c64259ac51e1f7aab94a8a8ff72b55c4
PYGAME_SDL2_VERSION=renpy-8.5.2.26010301

# Device OS: InkyOS / Buildroot ──────────────────────────────────────────────
# (replaces the archived pi-gen `os` repo — see adr/0007-buildroot-os.md)
BUILDROOT_VERSION=2026.05
TARGET_PYTHON_VERSION=3.14.5
HOST_CYTHON_VERSION=3.1.3

# Toolchain (workstation tooling: runtime, scripts) ──────────────────────────
PYTHON_VERSION=3.14
